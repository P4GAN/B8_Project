# Macro file for detector simulation
# 
# Magnetic field: 1.7T
# Default material thickness (0.07%, 0.25%, 0.55%)
# Hit resolution: 3 micrometres
# pi+ gun
# 5000000 runs

/det/materialWidth1 0.0007
/det/materialWidth2 0.0025
/det/materialWidth3 0.0055
/det/res 3 um

/run/initialize
/output/setFileName resolution_3um.root

/gun/particle pi+
/run/beamOn 5000000
