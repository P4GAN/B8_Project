# Macro file for detector simulation
# 
# Magnetic field: 1.7T
# x3 material thickness (0.21%, 0.75%, 1.65%)
# Hit resolution: 7 micrometres
# pi+ gun
# 5000000 runs

/det/materialWidth1 0.0021
/det/materialWidth2 0.0075
/det/materialWidth3 0.0165
/det/res 7 um

/run/initialize
/output/setFileName material_x3.root

/globalField/setValue 0 0 1.7 tesla

/gun/particle pi+
/run/beamOn 5000000
